# Hasura GraphQL (teacher flows, finance, legacy actions)
VITE_HASURA_URL=http://localhost:8082/v1/graphql

# Express REST API host (with or without /api/v1 — clients normalize automatically)
# Must match backend PORT (3004 nodemon) or Docker app port (3003)
VITE_API_URL=http://localhost:3003

VITE_HASURA_ADMIN_SECRET=supersecret
